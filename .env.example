# HuggingFace API Token (get from https://huggingface.co/settings/tokens)
# No model access request needed — HF Router handles it automatically
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Model Configuration
LLM_MODEL=LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db

# Artifacts Directory
ARTIFACTS_DIR=./artifacts

# Templates Directory
TEMPLATES_DIR=./templates

# App Configuration
APP_TITLE=AI Virtual Development Pod
MAX_TOKENS=2048
TEMPERATURE=0.7
